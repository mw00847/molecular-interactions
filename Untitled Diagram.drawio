          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-22" value="8. run the GNN model predicting the vibration for each concentration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="110" y="497.5" width="140" height="115" as="geometry" />
