          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-4" value="&lt;font face=&quot;Lucida Console&quot;&gt;1. optimise water acetone xyz complex&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="140" height="140" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-17" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="wuaWrtN5iVPU4nR-AbVH-7" target="wuaWrtN5iVPU4nR-AbVH-9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-7" value="2. center the oxygen on the carbonyl to 0,0,0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="130" height="120" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-14" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="wuaWrtN5iVPU4nR-AbVH-9" target="wuaWrtN5iVPU4nR-AbVH-13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-9" value="3. create 500 geometries of the water at different positions around the O on the carbonyl" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="430" y="40" width="150" height="180" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-15" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="wuaWrtN5iVPU4nR-AbVH-13" target="wuaWrtN5iVPU4nR-AbVH-16">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="610" y="260" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-13" value="4. run QM calculations on the 500 geometries taking features and vibrations for each geometry." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="620" y="120" width="120" height="200" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-19" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="wuaWrtN5iVPU4nR-AbVH-16" target="wuaWrtN5iVPU4nR-AbVH-18">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-16" value="5. create a .sdf of the 500 geometries to feed into a graph for GNN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="630" y="377.5" width="120" height="120" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-21" value="" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="wuaWrtN5iVPU4nR-AbVH-18" target="wuaWrtN5iVPU4nR-AbVH-20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-18" value="&lt;font&gt;6. determine the difference between the experimental carbonyl peak and the QM value for each geometry and concentration adding to the features&lt;span style=&quot;color: rgb(31, 31, 31); font-family: &amp;quot;Google Sans&amp;quot;, Arial, sans-serif; text-align: left; background-color: rgb(255, 255, 255);&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="430" y="490" width="150" height="130" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-23" style="edgeStyle=none;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="wuaWrtN5iVPU4nR-AbVH-20" target="wuaWrtN5iVPU4nR-AbVH-22">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="wuaWrtN5iVPU4nR-AbVH-20" value="7. combine the QM features wth the .sdf geometries into a graph&amp;nbsp;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="270" y="490" width="130" height="130" as="geometry" />
